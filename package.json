{
  "name": "navega-proxy-browser",
  "version": "0.2.0",
  "description": "Desktop browser with enforced proxy routing built with Electron.",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --dir",
    "lint": "node -e \"console.log('lint placeholder')\"",
    "typecheck": "node --check src/main/main.js && node --check src/main/proxyService.js && node --check src/main/managers.js && node --check src/main/preload.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.navega.proxybrowser",
    "productName": "Navega Proxy Browser",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.9.0",
    "csv-parse": "^5.5.6",
    "electron-store": "^10.0.1",
    "geoip-lite": "^1.4.10",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "electron": "^32.3.0",
    "electron-builder": "^24.13.3"
  }
}
